    "axios": "^1.14.0",
    "color": "^5.0.3",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "exceljs": "^4.4.0",
    "lodash-es": "^4.17.23",
    "net": "^1.0.2",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^8.4.0",
    "pinia": "^3.0.4",
    "sockjs-client": "1.6.1",
    "sortablejs": "^1.15.7",
    "stompjs": "^2.3.3",
    "vue": "^3.5.31",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "11.3.0",
    "vue-router": "^5.0.4",
    "vue3-element-admin": "file:",
    "xlsx": "^0.18.5"
  },
